{
  "version": 2,
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/cron/maintenance-reminders",
      "schedule": "0 14 * * *"
    }
  ]
}
